# GuardDuty Finding Types to Monitor
# 
# Specify Finding Types to monitor, separated by commas (no spaces).
# Leave empty ("") to monitor ALL GuardDuty findings.
# 
# See finding_types.md for the complete list of Finding Types.
# 
# Example - Monitor only high-risk IAM threats:
# FINDING_TYPES="UnauthorizedAccess:IAMUser/InstanceCredentialExfiltration.OutsideAWS,CredentialAccess:IAMUser/CompromisedCredentials,Policy:IAMUser/RootCredentialUsage,Stealth:IAMUser/CloudTrailLoggingDisabled"
# 
# Example - Monitor all IAM Unauthorized Access:
# FINDING_TYPES="UnauthorizedAccess:IAMUser/InstanceCredentialExfiltration.OutsideAWS,UnauthorizedAccess:IAMUser/InstanceCredentialExfiltration.InsideAWS,UnauthorizedAccess:IAMUser/MaliciousIPCaller,UnauthorizedAccess:IAMUser/MaliciousIPCaller.Custom,UnauthorizedAccess:IAMUser/TorIPCaller,UnauthorizedAccess:IAMUser/ConsoleLoginSuccess.B"
# 
# Example - High-risk threats including Attack Sequences:
# FINDING_TYPES="AttackSequence:IAM/CompromisedCredentials,AttackSequence:S3/CompromisedData,UnauthorizedAccess:IAMUser/InstanceCredentialExfiltration.OutsideAWS"
#
FINDING_TYPES=""

# S3 Bucket name for storing action logs
# 
# Leave empty ("") to auto-generate as "guardduty-auto-patcher-logs-<random>".
# Or specify a custom bucket name.
# 
# Examples:
# S3_BUCKET_NAME="my-company-guardduty-logs"
# S3_BUCKET_NAME=""  # Auto-generate
#
S3_BUCKET_NAME=""

# Excluded IAM Users (comma-separated, no spaces)
# 
# IAM Users in this list will be excluded from automatic remediation.
# Use this for service accounts, break-glass accounts, or critical automation users.
# 
# Examples:
# EXCLUDED_USERS="admin-user,service-account,break-glass-admin"
# EXCLUDED_USERS=""  # No exclusions
#
EXCLUDED_USERS=""

# Excluded IAM Roles (comma-separated, no spaces)
# 
# IAM Roles in this list will be excluded from automatic remediation.
# Use this for critical service roles or administrative roles.
# 
# Examples:
# EXCLUDED_ROLES="OrganizationAccountAccessRole,AWSServiceRoleForSupport"
# EXCLUDED_ROLES=""  # No exclusions
#
EXCLUDED_ROLES=""
